generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model DailyReward {
  id             String   @id @default(uuid())
  currentDay     Int      @default(1)
  lastClaimedAt  DateTime?
  totalCoins     Int      @default(0)
  cycleStartedAt DateTime @default(now())
}
