FROM node:20-alpine AS backend-build

WORKDIR /app

COPY backend/package.json backend/package-lock.json ./
RUN npm ci --production 2>/dev/null || npm install

COPY backend/tsconfig.json ./
COPY backend/prisma ./prisma
RUN npx prisma generate

FROM node:20-alpine

RUN apk add --no-cache \
    postgresql16-client \
    bash \
    curl

WORKDIR /app

# Copy backend from build stage
COPY --from=backend-build /app/node_modules ./node_modules
COPY --from=backend-build /app/prisma ./prisma
COPY backend/src ./src
COPY backend/package.json ./

# Install Lua 5.4 and LuaSocket for client tests
RUN apk add --no-cache \
    lua5.3 \
    lua5.3-dev \
    luarocks5.3 \
    make \
    gcc \
    musl-dev \
    openssl-dev

# Install busted (Lua test framework) and luasocket via LuaRocks
RUN luarocks-5.3 install busted && \
    luarocks-5.3 install socket.core

WORKDIR /app

CMD ["bash"]
